# ------------------------------------------------------------------------------
# Python & Bytecode
# ------------------------------------------------------------------------------
# 파이썬 컴파일된 바이트코드 무시
__pycache__/
*.py[cod]
*$py.class

# C 확장 모듈 무시
*.so

# ------------------------------------------------------------------------------
# Distribution / Packaging
# ------------------------------------------------------------------------------
# 패키징 빌드 아티팩트
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# Virtual Environment
# ------------------------------------------------------------------------------
# 가상환경 폴더 (venv, .venv, env 등)
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------------------------
# Unit Tests & Coverage
# ------------------------------------------------------------------------------
# Pytest 캐시 및 커버리지 리포트
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ------------------------------------------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------------------------------------------
# 환경변수 파일 (보안상 절대 커밋 금지)
.env
.env.*
!.env.example  # 예시 파일은 커밋 허용

# ------------------------------------------------------------------------------
# IDE & Editors
# ------------------------------------------------------------------------------
# VSCode, JetBrains 등 에디터 설정 파일
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------------------------
# Database & Logs
# ------------------------------------------------------------------------------
# SQLite DB 파일 등
*.sqlite3
*.db

# 로그 파일
*.log

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
# Docker 데이터 볼륨이나 임시 파일이 있다면 여기에 추가
# (현재 docker-compose.yml은 커밋 대상이나, data volume 마운트 경로는 주의)
backend/docker/postgres_data/

# ------------------------------------------------------------------------------
# OS Generated Types
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
